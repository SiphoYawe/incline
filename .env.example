# Incline — secret/config contract. Real values live in the Modal Secret
# `incline-secrets` (never commit real keys). This file documents the shape.

# ── Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=        # service role (Modal-side writes, bypasses RLS)
SUPABASE_ANON_KEY=           # dashboard read + realtime

# ── LLM — Hermes (Nous Research, OpenAI-compatible) ─────────────────────
HERMES_API_KEY=
HERMES_BASE_URL=https://inference-api.nousresearch.com/v1
HERMES_MODEL=Hermes-4-70B

# ── Reddit (LISTEN) ─────────────────────────────────────────────────────
# Default path is plain JSON HTTP — no keys required. PRAW vars are optional.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=incline/0.1 by <user>
REDDIT_SUBREDDITS=SomebodyMakeThis,Entrepreneur   # comma-separated target set

# ── X / Twitter (P1, optional — leave blank for P0) ─────────────────────
TWITTER_BEARER_TOKEN=

# ── PayPal sandbox (SELL → EARN) ────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_BASE=https://api-m.sandbox.paypal.com

# ── App ─────────────────────────────────────────────────────────────────
BASE_URL=                    # deployed Modal web URL (tool links + pay returns)
REPLY_MODE=draft             # draft | post   (draft = demo-safe default)
LOOP_PERIOD_SECONDS=60
